{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensaaslabs.org/schemas/evidence.schema.json",
  "title": "OpenSaaSLabs Learning Evidence",
  "type": "object",
  "required": ["id", "type", "subject", "claim", "status", "governance"],
  "properties": {
    "id": { "type": "string", "pattern": "^EVD-[0-9]{4}$" },
    "type": { "type": "string", "enum": ["lab", "project", "assessment", "review", "portfolio", "external"] },
    "subject": { "type": "string" },
    "claim": { "type": "string" },
    "artifact": { "type": "string" },
    "reviewer": { "type": "string" },
    "status": { "type": "string", "enum": ["submitted", "reviewed", "accepted", "rejected", "revoked"] },
    "governance": { "type": "object" }
  }
}
