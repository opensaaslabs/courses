{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensaaslabs.org/schemas/course.schema.json",
  "title": "OpenSaaSLabs Course",
  "type": "object",
  "required": ["id", "name", "version", "status", "level", "provider", "outcomes", "modules", "governance"],
  "properties": {
    "id": { "type": "string", "pattern": "^CRS-[0-9]{4}$" },
    "name": { "type": "string", "minLength": 3 },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "status": { "type": "string", "enum": ["draft", "review", "published", "deprecated", "archived"] },
    "level": { "type": "string", "enum": ["foundation", "associate", "practitioner", "professional", "expert"] },
    "durationHours": { "type": "number", "minimum": 0 },
    "provider": { "type": "string" },
    "description": { "type": "string" },
    "prerequisites": { "type": "array", "items": { "type": "string" } },
    "outcomes": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "skills": { "type": "array", "items": { "type": "string" } },
    "modules": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "labs": { "type": "array", "items": { "type": "string" } },
    "assessments": { "type": "array", "items": { "type": "string" } },
    "jsonld": { "type": "object" },
    "governance": {
      "type": "object",
      "required": ["owner", "reviewers", "license", "qualityGate"],
      "properties": {
        "owner": { "type": "string" },
        "reviewers": { "type": "array", "items": { "type": "string" } },
        "license": { "type": "string" },
        "qualityGate": { "type": "string", "enum": ["not-started", "in-progress", "passed", "failed"] },
        "trustScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "qualityScore": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
