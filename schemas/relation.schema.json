{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensaaslabs.org/schemas/relation.schema.json",
  "title": "OpenSaaSLabs Graph Relation",
  "type": "object",
  "required": ["id", "source", "type", "target", "status"],
  "properties": {
    "id": { "type": "string", "pattern": "^REL-[0-9]{4}$" },
    "source": { "type": "string" },
    "type": { "type": "string", "enum": ["contains", "teaches", "requires", "awards", "contributesTo", "validates", "evidencedBy", "issuedTo", "backedBy", "mapsTo"] },
    "target": { "type": "string" },
    "status": { "type": "string", "enum": ["draft", "active", "deprecated", "archived"] },
    "rationale": { "type": "string" },
    "governance": { "type": "object" }
  }
}
