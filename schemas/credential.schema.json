{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensaaslabs.org/schemas/credential.schema.json",
  "title": "OpenSaaSLabs Credential",
  "type": "object",
  "required": ["id", "holder", "issuer", "issuedAt", "evidence", "governance"],
  "properties": {
    "id": { "type": "string", "pattern": "^CRD-[0-9]{4}$" },
    "holder": { "type": "string" },
    "issuer": { "type": "string" },
    "badge": { "type": "string" },
    "certification": { "type": "string" },
    "issuedAt": { "type": "string" },
    "expiresAt": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "governance": { "type": "object" }
  }
}
