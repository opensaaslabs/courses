{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensaaslabs.org/schemas/learning-path.schema.json",
  "title": "OpenSaaSLabs Learning Path",
  "type": "object",
  "required": ["id", "name", "version", "status", "provider", "courses", "outcomes", "governance"],
  "properties": {
    "id": { "type": "string", "pattern": "^LP-[0-9]{4}$" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "status": { "type": "string" },
    "provider": { "type": "string" },
    "description": { "type": "string" },
    "courses": { "type": "array", "items": { "type": "string" } },
    "outcomes": { "type": "array", "items": { "type": "string" } },
    "governance": { "type": "object" }
  }
}
