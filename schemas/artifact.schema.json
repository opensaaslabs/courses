{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensaaslabs.org/schemas/artifact.schema.json",
  "title": "OpenSaaSLabs Universal Learning Artifact",
  "type": "object",
  "required": ["id", "type", "name", "version", "status", "governance"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "name": { "type": "string", "minLength": 3 },
    "description": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "status": { "type": "string", "enum": ["draft", "review", "published", "deprecated", "archived"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "relations": { "type": "array", "items": { "type": "object" } },
    "governance": {
      "type": "object",
      "required": ["owner", "license", "qualityGate"],
      "properties": {
        "owner": { "type": "string" },
        "reviewers": { "type": "array", "items": { "type": "string" } },
        "approvers": { "type": "array", "items": { "type": "string" } },
        "license": { "type": "string" },
        "qualityGate": { "type": "string" },
        "trustScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "qualityScore": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    }
  }
}
