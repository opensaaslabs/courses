{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://opensaaslabs.org/schemas/competency.schema.json",
  "title": "OpenSaaSLabs Competency",
  "type": "object",
  "required": ["id", "name", "version", "status", "levels", "governance"],
  "properties": {
    "id": { "type": "string", "pattern": "^COMP-[0-9]{4}$" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "status": { "type": "string" },
    "description": { "type": "string" },
    "levels": { "type": "array", "items": { "type": "object" } },
    "skills": { "type": "array", "items": { "type": "string" } },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "governance": { "type": "object" }
  }
}
